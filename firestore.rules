/**
 * @fileoverview Firestore Security Rules for Sol & Clay.
 *
 * NOTE: Firebase Authentication has been removed in favor of Clerk.
 * These rules have been updated to lock down all collections except for the
 * publicly readable 'collections' and 'products'.
 *
 * To write to the database, you must now:
 * 1. Create a backend API route in your Next.js application.
 * 2. In that API route, use the Clerk Node.js SDK to verify the user's JWT.
 * 3. Use the Firebase Admin SDK to perform any database operations.
 *
 * This ensures that only authenticated users can write to the database,
 * and all database operations are performed from a secure server environment.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to collections. Write access is not permitted from the client.
     */
    match /collections/{collectionId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to products. Write access is not permitted from the client.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Manages user profiles. Client-side access is disabled.
     */
    match /users/{userId} {
      allow read, write: if false;

      /**
       * @description Manages cart items for a specific user. Client-side access is disabled.
       */
      match /cartItems/{cartItemId} {
        allow read, write: if false;
      }
    }

    /**
     * @description Manages order data. Client-side access is disabled.
     */
    match /orders/{orderId} {
      allow read, write: if false;
    }

    /**
     * @description Manages custom order requests. Client-side access is disabled.
     */
    match /customOrders/{customOrderId} {
      allow read, write: if false;
    }

    /**
     * @description Manages collaboration requests. Client-side access is disabled.
     */
    match /collaborations/{collaborationId} {
      allow read, write: if false;
    }

    /**
     * @description Manages contact form submissions. Client-side access is disabled.
     */
    match /contacts/{contactId} {
      allow read, write: if false;
    }
    
    /**
     * @description Admin roles. Client-side access is disabled.
     */
    match /roles_admin/{userId} {
        allow read, write: if false;
    }
  }
}
